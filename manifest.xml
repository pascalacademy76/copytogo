<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<OfficeApp xmlns="http://schemas.microsoft.com/office/appforoffice/1.1" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:bt="http://schemas.microsoft.com/office/officeappbasictypes/1.0" xmlns:ov="http://schemas.microsoft.com/office/taskpaneappversionoverrides" xsi:type="TaskPaneApp">
  <Id>05578dc9-3990-44b0-b028-36ff5a416cb3</Id>
  <Version>1.0.0.0</Version>
  <ProviderName>Pascal Academy</ProviderName>
  <DefaultLocale>nl-NL</DefaultLocale>
  <DisplayName DefaultValue="CopyToGo"/>
  <Description DefaultValue="Kopieer en plak afbeelding-eigenschappen in PowerPoint. Door Pascal Academy."/>
  <IconUrl DefaultValue="https://pascalacademy76.github.io/copytogo/assets/logo-filled.png"/>
  <HighResolutionIconUrl DefaultValue="https://pascalacademy76.github.io/copytogo/assets/logo-filled.png"/>
  <SupportUrl DefaultValue="https://pascal.academy"/>
  <AppDomains>
    <AppDomain>https://pascalacademy76.github.io</AppDomain>
  </AppDomains>
  <Hosts>
    <Host Name="Presentation"/>
  </Hosts>
  <DefaultSettings>
    <SourceLocation DefaultValue="https://pascalacademy76.github.io/copytogo/src/taskpane/taskpane.html"/>
  </DefaultSettings>
  <Permissions>ReadWriteDocument</Permissions>
  <VersionOverrides xmlns="http://schemas.microsoft.com/office/taskpaneappversionoverrides" xsi:type="VersionOverridesV1_0">
    <Hosts>
      <Host xsi:type="Presentation">
        <DesktopFormFactor>
          <GetStarted>
            <Title resid="GetStarted.Title"/>
            <Description resid="GetStarted.Description"/>
            <LearnMoreUrl resid="GetStarted.LearnMoreUrl"/>
          </GetStarted>
          <FunctionFile resid="Commands.Url"/>
          <ExtensionPoint xsi:type="PrimaryCommandSurface">
            <OfficeTab id="TabHome">
              <Group id="CommandsGroup">
                <Label resid="CommandsGroup.Label"/>
                <Icon>
                  <bt:Image size="16" resid="Icon.16x16"/>
                  <bt:Image size="32" resid="Icon.32x32"/>
                  <bt:Image size="80" resid="Icon.80x80"/>
                </Icon>
                <Control xsi:type="Button" id="TaskpaneButton">
                  <Label resid="TaskpaneButton.Label"/>
                  <Supertip>
                    <Title resid="TaskpaneButton.Label"/>
                    <Description resid="TaskpaneButton.Tooltip"/>
                  </Supertip>
                  <Icon>
                    <bt:Image size="16" resid="Icon.16x16"/>
                    <bt:Image size="32" resid="Icon.32x32"/>
                    <bt:Image size="80" resid="Icon.80x80"/>
                  </Icon>
                  <Action xsi:type="ShowTaskpane">
                    <TaskpaneId>ButtonId1</TaskpaneId>
                    <SourceLocation resid="Taskpane.Url"/>
                  </Action>
                </Control>
              </Group>
            </OfficeTab>
          </ExtensionPoint>
        </DesktopFormFactor>
      </Host>
    </Hosts>
    <Resources>
      <bt:Images>
        <bt:Image id="Icon.16x16" DefaultValue="https://pascalacademy76.github.io/copytogo/assets/logo-filled.png"/>
        <bt:Image id="Icon.32x32" DefaultValue="https://pascalacademy76.github.io/copytogo/assets/logo-filled.png"/>
        <bt:Image id="Icon.80x80" DefaultValue="https://pascalacademy76.github.io/copytogo/assets/logo-filled.png"/>
      </bt:Images>
      <bt:Urls>
        <bt:Url id="GetStarted.LearnMoreUrl" DefaultValue="https://pascal.academy"/>
        <bt:Url id="Commands.Url" DefaultValue="https://pascalacademy76.github.io/copytogo/src/commands/commands.html"/>
        <bt:Url id="Taskpane.Url" DefaultValue="https://pascalacademy76.github.io/copytogo/src/taskpane/taskpane.html"/>
      </bt:Urls>
      <bt:ShortStrings>
        <bt:String id="GetStarted.Title" DefaultValue="Welkom bij CopyToGo!"/>
        <bt:String id="CommandsGroup.Label" DefaultValue="CopyToGo"/>
        <bt:String id="TaskpaneButton.Label" DefaultValue="CopyToGo"/>
      </bt:ShortStrings>
      <bt:LongStrings>
        <bt:String id="GetStarted.Description" DefaultValue="Kopieer en plak afbeelding-eigenschappen met één klik. Klik op de CopyToGo knop in het lint om te beginnen."/>
        <bt:String id="TaskpaneButton.Tooltip" DefaultValue="Open CopyToGo om afbeelding-eigenschappen te kopiëren en plakken"/>
      </bt:LongStrings>
    </Resources>
  </VersionOverrides>
</OfficeApp>
